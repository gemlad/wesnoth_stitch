{
  "name": "wesnoth-stitch",
  "version": "0.1.0",
  "description": "Convert Battle for Wesnoth unit sprites into cross-stitch patterns",
  "main": "./out/main/index.js",
  "author": "Gemma Wright, coauthored by Claude (Opus 4.8)",
  "homepage": "https://github.com/gemlad/wesnoth_stitch",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "validate:cap": "node scripts/run-ts.mjs scripts/validate-cap.ts",
    "measure:ink": "npm run validate:cap && electron scripts/measure-glyph-ink.mjs",
    "assign:compare": "node scripts/run-ts.mjs scripts/assignment-compare.ts",
    "uat": "npm run uat:chart && npm run uat:legibility",
    "uat:chart": "node scripts/run-ts.mjs scripts/uat-chart.ts",
    "uat:legibility": "node scripts/run-ts.mjs scripts/legibility-sheet.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@types/pngjs": "^6.0.5",
    "culori": "^4.0.2",
    "pdf-lib": "^1.17.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "konva": "^10.3.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-konva": "^19.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.10"
  }
}
